<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="検索GUI" Width="800" Height="480">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左ペインは残り全部 -->
            <ColumnDefinition Width="*"/>
            <!-- 右ペインは固定幅 -->
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左ペイン -->
        <StackPanel Grid.Column="0" Margin="10">
            <ContentControl x:Name="SearchComboHost"/>
            <ContentControl x:Name="ResultGridHost" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- 右ペイン -->
        <ContentControl x:Name="DetailGridHost" Grid.Column="1" Margin="10"/>

        <!-- ステータスバー -->
        <DockPanel VerticalAlignment="Bottom" LastChildFill="True" Margin="2,0,2,2">
            <TextBlock x:Name="StatusText" Text="準備完了"
                       VerticalAlignment="Center" FontSize="12" Padding="2,2"/>
        </DockPanel>
    </Grid>
</Window>