<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 検索コンボ -->
    <ComboBox x:Key="SearchCombo"
        Width="240"
        IsEditable="True"
        IsTextSearchEnabled="False"
        FontSize="16" />

    <!-- 結果グリッド -->
    <DataGrid x:Key="ResultGrid"
        Height="300"
        FontSize="16"
        AutoGenerateColumns="True"
        IsReadOnly="True"
        SelectionMode="Single"
        SelectionUnit="FullRow">

        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
                <Style.Triggers>
                    <!-- 履歴一致行を黄色で -->
                    <DataTrigger Binding="{Binding _IsHistoryMatch}" Value="True">
                        <Setter Property="Background" Value="LightYellow" />
                    </DataTrigger>
                    <!-- 選択行を緑で -->
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="LightGreen" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </DataGrid.RowStyle>
    </DataGrid>

    <!-- 詳細グリッド -->
    <DataGrid x:Key="DetailGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
        HeadersVisibility="Column"
        RowHeaderWidth="0"
        SelectionMode="Extended"
        SelectionUnit="FullRow"
        FontSize="16">
        <DataGrid.Columns>
            <DataGridTextColumn Header="項目" Binding="{Binding 項目}" />
            <DataGridTextColumn Header="値" Binding="{Binding 値}" />
        </DataGrid.Columns>
    </DataGrid>

    <!-- 詳細リスト -->
    <ListBox x:Key="DetailList"
        FontSize="16"
        SelectionMode="Extended"
        Margin="4">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="2">
                    <!-- 表示は「項目: 値」 -->
                    <TextBlock Text="{Binding 項目}" FontWeight="Bold" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding 値}" TextWrapping="Wrap" />
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</ResourceDictionary>