  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug with Local Module",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "DEBUG_MODE": "true"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Node.js Script",
      "program": "${workspaceFolder}/cheerio-runner.js"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Node.js",
      "port": 9229
    }
  ]
}
