<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher" Height="500" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button x:Name="RunButton" Content="PowerShell起動"
                Width="200" Height="50" />

        <TextBox x:Name="ConsoleBox" Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="14"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 AcceptsReturn="True"
                 AcceptsTab="True"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 FontFamily="Consolas"
                 FontSize="14"
                 Height="30"/>
    </Grid>
</Window>